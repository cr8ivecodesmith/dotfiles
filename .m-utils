# M-Utils Configuration File
# This file stores settings for the m-utils system utility collection.
# It will be automatically created and updated by m-utils commands.

[laptop.lid_close]
# Lid close behavior configuration
# Each power mode (battery/ac) can have different settings
#
# Format:
# [power_mode]
#   action = "sleep"
#   value = false | 0 | <minutes>
#
# Where:
#   false = disabled (do nothing when lid closes)
#   0 = immediate suspend
#   <minutes> = delay in minutes before suspending
#
# Example configurations:
# battery = { action = "sleep", value = 15 }  # Sleep after 15 minutes on battery
# ac = { action = "sleep", value = false }    # Don't sleep on AC power
