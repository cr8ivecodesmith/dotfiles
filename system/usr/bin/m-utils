#!/usr/bin/env python3
"""
m-utils: Matt's system utility collection
A centralized script for managing system configurations and utilities.
"""

import argparse
import os
import sys
import subprocess
from pathlib import Path
from typing import Dict, Any

try:
    import tomllib  # Python 3.11+ built-in
except ImportError:
    try:
        import tomli as tomllib  # Fallback for Python < 3.11
    except ImportError:
        print("Error: TOML library not available.", file=sys.stderr)
        print("For Python < 3.11, install with: pip install tomli tomli-w", file=sys.stderr)
        sys.exit(1)

try:
    import tomli_w
except ImportError:
    print("Error: tomli_w not installed (required for writing config).", file=sys.stderr)
    print("Install with: pip install tomli-w", file=sys.stderr)
    sys.exit(1)


CONFIG_FILE = Path.home() / ".m-utils"

# Get template location from environment variable or fall back to relative path
# MUTILS_DOTFILES_DIR should be set by init-system.sh
if "MUTILS_DOTFILES_DIR" in os.environ:
    CONFIG_TEMPLATE = Path(os.environ["MUTILS_DOTFILES_DIR"]) / ".m-utils-template"
else:
    # Fallback: try to find template relative to script location
    # This works if script is still in dotfiles repo (not copied to /usr/bin yet)
    CONFIG_TEMPLATE = Path(__file__).resolve().parent.parent.parent / ".m-utils-template"

LOGIND_CONF = Path("/etc/systemd/logind.conf")
LOGIND_CONF_D = Path("/etc/systemd/logind.conf.d")
TIMER_DIR = Path("/etc/systemd/system")


def load_config() -> Dict[str, Any]:
    """Load configuration from TOML file."""
    if not CONFIG_FILE.exists():
        # Try to create from template
        if CONFIG_TEMPLATE.exists():
            print("Info: Creating ~/.m-utils from template...", file=sys.stderr)
            try:
                import shutil
                shutil.copy2(CONFIG_TEMPLATE, CONFIG_FILE)
                print("✓ Config file created. Edit ~/.m-utils to customize.", file=sys.stderr)
            except Exception as e:
                print(f"Warning: Could not copy template: {e}", file=sys.stderr)
                print("Please manually copy .m-utils-template to ~/.m-utils", file=sys.stderr)
                return {}
        else:
            print("Warning: No config file found at ~/.m-utils", file=sys.stderr)
            print("Create it from the template or m-utils will use defaults.", file=sys.stderr)
            return {}
    
    try:
        with open(CONFIG_FILE, "rb") as f:
            return tomllib.load(f)
    except Exception as e:
        print(f"Error: Failed to load config file: {e}", file=sys.stderr)
        return {}


def save_config(config: Dict[str, Any]) -> None:
    """Save configuration to TOML file."""
    # Ensure config directory exists
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    
    with open(CONFIG_FILE, "wb") as f:
        tomli_w.dump(config, f)


def is_root() -> bool:
    """Check if running as root."""
    return os.geteuid() == 0


def elevate_if_needed() -> None:
    """Re-execute script with sudo if not running as root."""
    if not is_root():
        args = ["sudo", "-E", sys.executable] + sys.argv
        os.execvp("sudo", args)


def run_command(cmd: list, check: bool = True) -> subprocess.CompletedProcess:
    """Run a shell command."""
    return subprocess.run(cmd, check=check, capture_output=True, text=True)


def restart_logind() -> None:
    """Restart systemd-logind service."""
    print("Restarting systemd-logind...")
    run_command(["systemctl", "restart", "systemd-logind"])


def set_logind_setting(key: str, value: str) -> None:
    """Set a logind.conf setting using drop-in file."""
    LOGIND_CONF_D.mkdir(parents=True, exist_ok=True)
    dropin_file = LOGIND_CONF_D / "m-utils-lid.conf"
    
    # Read existing settings
    settings = {}
    if dropin_file.exists():
        with open(dropin_file, "r") as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    settings[k] = v
    
    # Update setting
    settings[key] = value
    
    # Write back
    with open(dropin_file, "w") as f:
        f.write("[Login]\n")
        for k, v in settings.items():
            f.write(f"{k}={v}\n")


def create_suspend_timer(power_mode: str, delay_minutes: int) -> None:
    """Create a systemd timer to suspend after delay."""
    service_name = f"m-utils-suspend-{power_mode}.service"
    timer_name = f"m-utils-suspend-{power_mode}.timer"
    
    service_path = TIMER_DIR / service_name
    timer_path = TIMER_DIR / timer_name
    
    # Create service unit
    service_content = f"""[Unit]
Description=M-Utils Delayed Suspend ({power_mode})
After=suspend.target

[Service]
Type=oneshot
ExecStart=/usr/bin/systemctl suspend

[Install]
WantedBy=default.target
"""
    
    with open(service_path, "w") as f:
        f.write(service_content)
    
    # Create timer unit
    timer_content = f"""[Unit]
Description=M-Utils Delayed Suspend Timer ({power_mode})

[Timer]
OnActiveSec={delay_minutes}min
RemainAfterElapse=no

[Install]
WantedBy=timers.target
"""
    
    with open(timer_path, "w") as f:
        f.write(timer_content)
    
    # Reload systemd
    run_command(["systemctl", "daemon-reload"])


def remove_suspend_timer(power_mode: str) -> None:
    """Remove systemd timer for delayed suspend."""
    service_name = f"m-utils-suspend-{power_mode}.service"
    timer_name = f"m-utils-suspend-{power_mode}.timer"
    
    service_path = TIMER_DIR / service_name
    timer_path = TIMER_DIR / timer_name
    
    # Stop and disable timer
    run_command(["systemctl", "stop", timer_name], check=False)
    run_command(["systemctl", "disable", timer_name], check=False)
    
    # Remove files
    if service_path.exists():
        service_path.unlink()
    if timer_path.exists():
        timer_path.unlink()
    
    # Reload systemd
    run_command(["systemctl", "daemon-reload"])


def remove_all_lid_configs() -> None:
    """Remove all m-utils lid close configurations from the system."""
    elevate_if_needed()
    
    print("Removing all m-utils lid close configurations...")
    
    # Remove logind drop-in file
    dropin_file = LOGIND_CONF_D / "m-utils-lid.conf"
    if dropin_file.exists():
        dropin_file.unlink()
        print(f"✓ Removed {dropin_file}")
    else:
        print("  No logind drop-in file found")
    
    # Remove timers for both power modes
    for power_mode in ["battery", "ac"]:
        service_name = f"m-utils-suspend-{power_mode}.service"
        timer_name = f"m-utils-suspend-{power_mode}.timer"
        
        service_path = TIMER_DIR / service_name
        timer_path = TIMER_DIR / timer_name
        
        removed_any = False
        
        # Stop and disable timer
        result = run_command(["systemctl", "stop", timer_name], check=False)
        if result.returncode == 0:
            removed_any = True
        
        run_command(["systemctl", "disable", timer_name], check=False)
        
        # Remove files
        if service_path.exists():
            service_path.unlink()
            removed_any = True
        
        if timer_path.exists():
            timer_path.unlink()
            removed_any = True
        
        if removed_any:
            print(f"✓ Removed {power_mode} timer/service")
    
    # Reload systemd
    run_command(["systemctl", "daemon-reload"])
    
    # Clear config file settings but keep the file
    config = load_config()
    if "laptop" in config and "lid_close" in config["laptop"]:
        del config["laptop"]["lid_close"]
        if not config["laptop"]:  # Remove empty laptop section
            del config["laptop"]
        save_config(config)
        print("✓ Cleared settings from config file")
    
    restart_logind()
    print("\n✓ All m-utils lid close configurations removed successfully!")
    print("  System will now use default behavior.")


def check_system_config_active() -> Dict[str, bool]:
    """Check if m-utils configurations are actually active in the system."""
    status = {"logind_dropin_exists": False, "battery_timer_exists": False, "ac_timer_exists": False}
    
    # Check logind drop-in
    dropin_file = LOGIND_CONF_D / "m-utils-lid.conf"
    status["logind_dropin_exists"] = dropin_file.exists()
    
    # Check timers
    for power_mode in ["battery", "ac"]:
        timer_name = f"m-utils-suspend-{power_mode}.timer"
        timer_path = TIMER_DIR / timer_name
        status[f"{power_mode}_timer_exists"] = timer_path.exists()
    
    return status


def handle_lid_close_set(power_mode: str, action: str, value: str) -> None:
    """Handle setting lid close behavior."""
    elevate_if_needed()
    
    config = load_config()
    if "laptop" not in config:
        config["laptop"] = {}
    if "lid_close" not in config["laptop"]:
        config["laptop"]["lid_close"] = {}
    
    # Determine HandleLidSwitch key based on power mode
    handle_key = f"HandleLidSwitch{'ExternalPower' if power_mode == 'ac' else ''}"
    
    if action == "sleep":
        if value == "false":
            # Disable sleep
            set_logind_setting(handle_key, "ignore")
            remove_suspend_timer(power_mode)
            config["laptop"]["lid_close"][power_mode] = {"action": "sleep", "value": "false"}
            print(f"Lid close on {power_mode}: disabled (ignore)")
        
        elif value == "0":
            # Immediate sleep
            set_logind_setting(handle_key, "suspend")
            remove_suspend_timer(power_mode)
            config["laptop"]["lid_close"][power_mode] = {"action": "sleep", "value": 0}
            print(f"Lid close on {power_mode}: immediate suspend")
        
        else:
            # Delayed sleep
            try:
                delay_minutes = int(value)
                if delay_minutes < 0:
                    print("Error: Delay must be non-negative", file=sys.stderr)
                    sys.exit(1)
                
                set_logind_setting(handle_key, "ignore")
                create_suspend_timer(power_mode, delay_minutes)
                config["laptop"]["lid_close"][power_mode] = {"action": "sleep", "value": delay_minutes}
                print(f"Lid close on {power_mode}: suspend after {delay_minutes} minutes")
            
            except ValueError:
                print(f"Error: Invalid delay value: {value}", file=sys.stderr)
                sys.exit(1)
    
    save_config(config)
    restart_logind()
    print("Configuration updated successfully!")


def handle_lid_close_status() -> None:
    """Show current lid close settings."""
    config = load_config()
    system_status = check_system_config_active()
    
    # Check if any m-utils configs are active
    is_active = any(system_status.values())
    
    print("Laptop Lid Close Settings:")
    print("=" * 50)
    
    if is_active:
        print("Status: ✓ m-utils configuration ACTIVE")
    else:
        print("Status: ○ m-utils configuration INACTIVE (using system defaults)")
    
    print("=" * 50)
    
    for power_mode in ["battery", "ac"]:
        settings = config.get("laptop", {}).get("lid_close", {}).get(power_mode)
        
        if settings:
            action = settings.get("action")
            value = settings.get("value")
            
            if action == "sleep":
                if value == "false":
                    status = "Disabled (do nothing)"
                elif value == 0:
                    status = "Immediate suspend"
                else:
                    status = f"Suspend after {value} minutes"
            else:
                status = "Unknown"
        else:
            status = "Not configured (system default)"
        
        print(f"{power_mode.upper():8s}: {status}")
    
    # Show system file status
    if is_active:
        print("\nSystem Files:")
        print("-" * 50)
        if system_status["logind_dropin_exists"]:
            print("  ✓ Logind drop-in: /etc/systemd/logind.conf.d/m-utils-lid.conf")
        if system_status["battery_timer_exists"]:
            print("  ✓ Battery timer: /etc/systemd/system/m-utils-suspend-battery.timer")
        if system_status["ac_timer_exists"]:
            print("  ✓ AC timer: /etc/systemd/system/m-utils-suspend-ac.timer")


def check_ufw_installed() -> bool:
    """Check if UFW is installed."""
    result = run_command(["which", "ufw"], check=False)
    return result.returncode == 0


def get_ufw_status() -> Dict[str, Any]:
    """Get current UFW status and rules."""
    result = run_command(["ufw", "status", "verbose"], check=False)
    
    status = {
        "enabled": False,
        "default_incoming": "unknown",
        "default_outgoing": "unknown",
        "rules": []
    }
    
    if result.returncode != 0:
        return status
    
    for line in result.stdout.split("\n"):
        line = line.strip()
        if "Status:" in line:
            status["enabled"] = "active" in line.lower()
        elif "Default:" in line and "incoming" in line.lower():
            if "deny" in line.lower():
                status["default_incoming"] = "deny"
            elif "allow" in line.lower():
                status["default_incoming"] = "allow"
        elif "Default:" in line and "outgoing" in line.lower():
            if "deny" in line.lower():
                status["default_outgoing"] = "deny"
            elif "allow" in line.lower():
                status["default_outgoing"] = "allow"
    
    return status


def parse_existing_ufw_rules() -> list:
    """Parse existing UFW rules from 'ufw status numbered'."""
    result = run_command(["ufw", "status", "numbered"], check=False)
    
    if result.returncode != 0:
        return []
    
    rules = []
    lines = result.stdout.split("\n")
    
    for line in lines:
        line = line.strip()
        # Skip headers and empty lines
        if not line or "Status:" in line or "To" in line and "Action" in line:
            continue
        
        # Parse numbered rules like: "[ 1] 22/tcp                     ALLOW IN    Anywhere"
        if line.startswith("["):
            try:
                # Remove the rule number
                parts = line.split("]", 1)
                if len(parts) < 2:
                    continue
                
                rule_text = parts[1].strip()
                
                # Split by multiple spaces to get fields
                fields = [f for f in rule_text.split() if f]
                
                if len(fields) < 3:
                    continue
                
                # Parse port/protocol
                port_proto = fields[0]
                action = fields[1].upper()
                direction = fields[2].upper() if len(fields) > 2 else "IN"
                
                # Only process ALLOW IN and LIMIT IN rules (skip v6 duplicates)
                if direction == "IN" and action in ["ALLOW", "LIMIT", "DENY"]:
                    # Parse port and protocol
                    if "/" in port_proto:
                        port, protocol = port_proto.split("/", 1)
                    else:
                        port = port_proto
                        protocol = "any"
                    
                    # Determine action
                    if action == "LIMIT":
                        parsed_action = "limit"
                    elif action == "ALLOW":
                        parsed_action = "allow"
                    else:
                        parsed_action = "deny"
                    
                    rules.append({
                        "port": port,
                        "protocol": protocol.lower(),
                        "action": parsed_action
                    })
            
            except Exception:
                # Skip malformed lines
                continue
    
    return rules


def merge_rules_to_config(existing_rules: list) -> None:
    """Merge existing UFW rules into the config file."""
    config = load_config()
    
    if "firewall" not in config:
        config["firewall"] = {}
    
    if "rules" not in config["firewall"]:
        config["firewall"]["rules"] = []
    
    # Get existing config rules for comparison
    config_rules = config["firewall"]["rules"]
    
    # Track which rules are new
    new_rules = []
    
    for existing_rule in existing_rules:
        # Check if this rule already exists in config
        is_duplicate = False
        
        for config_rule in config_rules:
            # Match on port and protocol
            config_port = str(config_rule.get("port", ""))
            config_protocol = config_rule.get("protocol", "tcp")
            
            if (config_port == existing_rule["port"] and 
                config_protocol == existing_rule["protocol"]):
                is_duplicate = True
                break
        
        if not is_duplicate:
            new_rules.append(existing_rule)
    
    if new_rules:
        # Add comment for merged rules
        for rule in new_rules:
            rule["comment"] = "Merged from existing UFW rule"
            config["firewall"]["rules"].append(rule)
        
        save_config(config)
        print(f"\n✓ Merged {len(new_rules)} existing rule(s) into ~/.m-utils")
        for rule in new_rules:
            print(f"  - {rule['action'].upper()} {rule['port']}/{rule['protocol']}")
    else:
        print("\n  No new rules to merge (all existing rules already in config)")


def apply_firewall_rules() -> None:
    """Apply firewall rules from config to UFW."""
    elevate_if_needed()
    
    if not check_ufw_installed():
        print("Error: UFW is not installed. Install with: sudo apt install ufw", file=sys.stderr)
        sys.exit(1)
    
    config = load_config()
    firewall_config = config.get("firewall", {})
    rules = firewall_config.get("rules", [])
    
    if not rules:
        print("Warning: No firewall rules defined in config file", file=sys.stderr)
        print("Edit ~/.m-utils to add firewall rules")
        return
    
    # Check for existing UFW rules
    existing_rules = parse_existing_ufw_rules()
    
    if existing_rules:
        print("=" * 50)
        print("⚠  WARNING: Existing UFW rules detected")
        print("=" * 50)
        print(f"\nFound {len(existing_rules)} existing rule(s):")
        for rule in existing_rules:
            print(f"  - {rule['action'].upper()} {rule['port']}/{rule['protocol']}")
        
        print("\nApplying m-utils firewall configuration will RESET all UFW rules.")
        print("\nOptions:")
        print("  [m] Merge existing rules into ~/.m-utils and apply all rules")
        print("  [o] Override (reset UFW and apply only rules from ~/.m-utils)")
        print("  [c] Cancel")
        
        while True:
            choice = input("\nYour choice [m/o/c]: ").strip().lower()
            
            if choice == "c":
                print("\nCancelled. No changes made.")
                sys.exit(0)
            elif choice == "m":
                print("\nMerging existing rules into config...")
                merge_rules_to_config(existing_rules)
                # Reload config after merge
                config = load_config()
                firewall_config = config.get("firewall", {})
                rules = firewall_config.get("rules", [])
                break
            elif choice == "o":
                print("\nProceeding with override...")
                break
            else:
                print("Invalid choice. Please enter 'm', 'o', or 'c'.")
    
    print("\nApplying firewall configuration...")
    print("=" * 50)
    
    # Set default policies
    print("Setting default policies...")
    run_command(["ufw", "default", "deny", "incoming"])
    print("  ✓ Default incoming: deny")
    run_command(["ufw", "default", "allow", "outgoing"])
    print("  ✓ Default outgoing: allow")
    
    # Get current UFW status to check if enabled
    ufw_status = get_ufw_status()
    was_enabled = ufw_status["enabled"]
    
    # Disable UFW temporarily to reset rules
    if was_enabled:
        run_command(["ufw", "--force", "disable"])
    
    # Reset UFW to clear all rules
    run_command(["ufw", "--force", "reset"])
    
    # Reapply default policies after reset
    run_command(["ufw", "default", "deny", "incoming"])
    run_command(["ufw", "default", "allow", "outgoing"])
    
    # Apply rules from config
    print("\nApplying port rules...")
    for rule in rules:
        port = rule.get("port")
        protocol = rule.get("protocol", "tcp")
        action = rule.get("action", "allow")
        comment = rule.get("comment", "")
        
        if port is None:
            print("  ⚠ Skipping rule with no port specified", file=sys.stderr)
            continue
        
        # Build UFW command
        cmd = ["ufw"]
        
        if action == "limit":
            cmd.append("limit")
        else:
            cmd.extend([action])
        
        # Handle port specification
        port_str = str(port)
        if protocol != "any":
            cmd.append(f"{port_str}/{protocol}")
        else:
            cmd.append(port_str)
        
        # Add comment if provided
        if comment:
            cmd.extend(["comment", comment])
        
        try:
            run_command(cmd)
            comment_str = f" # {comment}" if comment else ""
            print(f"  ✓ {action.upper()} {port_str}/{protocol}{comment_str}")
        except subprocess.CalledProcessError as e:
            print(f"  ✗ Failed to apply rule: {port_str}/{protocol}", file=sys.stderr)
            print(f"    Error: {e.stderr}", file=sys.stderr)
    
    # Enable UFW
    print("\nEnabling firewall...")
    run_command(["ufw", "--force", "enable"])
    print("  ✓ Firewall enabled")
    
    print("\n" + "=" * 50)
    print("✓ Firewall configuration applied successfully!")


def handle_firewall_status() -> None:
    """Show current firewall status."""
    # Note: status command needs sudo for full details
    elevate_if_needed()
    
    if not check_ufw_installed():
        print("Error: UFW is not installed. Install with: sudo apt install ufw", file=sys.stderr)
        sys.exit(1)
    
    print("Firewall Status:")
    print("=" * 50)
    
    # Get UFW status
    result = run_command(["ufw", "status", "verbose"], check=False)
    if result.returncode == 0:
        print(result.stdout)
    else:
        print("Error: Unable to get firewall status", file=sys.stderr)
        print(result.stderr, file=sys.stderr)
        return
    
    # Show existing UFW rules count
    existing_rules = parse_existing_ufw_rules()
    if existing_rules:
        print(f"\nActive UFW Rules: {len(existing_rules)} rule(s)")
    
    print("\nConfigured Rules (~/.m-utils):")
    print("=" * 50)
    
    config = load_config()
    firewall_config = config.get("firewall", {})
    rules = firewall_config.get("rules", [])
    
    if rules:
        for i, rule in enumerate(rules, 1):
            port = rule.get("port")
            protocol = rule.get("protocol", "tcp")
            action = rule.get("action", "allow")
            comment = rule.get("comment", "")
            
            comment_str = f" # {comment}" if comment else ""
            print(f"{i}. {action.upper()} {port}/{protocol}{comment_str}")
    else:
        print("No rules configured in ~/.m-utils")
    
    print("\nTo modify rules, edit: ~/.m-utils")
    print("Then run: m-utils firewall update")


def handle_firewall_enable() -> None:
    """Enable UFW firewall."""
    elevate_if_needed()
    
    if not check_ufw_installed():
        print("Error: UFW is not installed. Install with: sudo apt install ufw", file=sys.stderr)
        sys.exit(1)
    
    print("Enabling firewall...")
    run_command(["ufw", "--force", "enable"])
    print("✓ Firewall enabled")


def handle_firewall_disable() -> None:
    """Disable UFW firewall."""
    elevate_if_needed()
    
    if not check_ufw_installed():
        print("Error: UFW is not installed. Install with: sudo apt install ufw", file=sys.stderr)
        sys.exit(1)
    
    print("Disabling firewall...")
    run_command(["ufw", "disable"])
    print("✓ Firewall disabled")


def main():
    parser = argparse.ArgumentParser(
        description="Matt's system utility collection",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")
    
    # laptop command
    laptop_parser = subparsers.add_parser("laptop", help="Laptop-specific utilities")
    laptop_subparsers = laptop_parser.add_subparsers(dest="laptop_command")
    
    # laptop lid-close command
    lid_parser = laptop_subparsers.add_parser("lid-close", help="Configure lid close behavior")
    lid_subparsers = lid_parser.add_subparsers(dest="lid_action")
    
    # lid-close status
    lid_subparsers.add_parser("status", help="Show current lid close settings")
    
    # lid-close remove
    lid_subparsers.add_parser("remove", help="Remove all m-utils lid close configurations")
    
    # lid-close set (battery/ac)
    set_parser = lid_subparsers.add_parser("battery", help="Configure battery power mode")
    set_parser.add_argument("action", choices=["sleep"], help="Action to perform")
    set_parser.add_argument("value", help="Value (delay in minutes, 0=immediate, false=disabled)")
    
    set_parser = lid_subparsers.add_parser("ac", help="Configure AC power mode")
    set_parser.add_argument("action", choices=["sleep"], help="Action to perform")
    set_parser.add_argument("value", help="Value (delay in minutes, 0=immediate, false=disabled)")
    
    # firewall command
    firewall_parser = subparsers.add_parser("firewall", help="Manage UFW firewall configuration")
    firewall_subparsers = firewall_parser.add_subparsers(dest="firewall_action")
    
    # firewall subcommands
    firewall_subparsers.add_parser("status", help="Show current firewall status and rules")
    firewall_subparsers.add_parser("update", help="Apply firewall rules from config file")
    firewall_subparsers.add_parser("enable", help="Enable the firewall")
    firewall_subparsers.add_parser("disable", help="Disable the firewall")
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    if args.command == "laptop":
        if not args.laptop_command:
            laptop_parser.print_help()
            sys.exit(1)
        
        if args.laptop_command == "lid-close":
            if not args.lid_action:
                lid_parser.print_help()
                sys.exit(1)
            
            if args.lid_action == "status":
                handle_lid_close_status()
            elif args.lid_action == "remove":
                remove_all_lid_configs()
            elif args.lid_action in ["battery", "ac"]:
                handle_lid_close_set(args.lid_action, args.action, args.value)
    
    elif args.command == "firewall":
        if not args.firewall_action:
            firewall_parser.print_help()
            sys.exit(1)
        
        if args.firewall_action == "status":
            handle_firewall_status()
        elif args.firewall_action == "update":
            apply_firewall_rules()
        elif args.firewall_action == "enable":
            handle_firewall_enable()
        elif args.firewall_action == "disable":
            handle_firewall_disable()


if __name__ == "__main__":
    main()
